rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function signedInRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && signedInRole() == 'admin';
    }

    function isWorker() {
      return isAuth() && signedInRole() in ['worker', 'admin'];
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function validSurveyCreate() {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.status in ['proper', 'minorMixing', 'mixedWaste', 'hazardous']
        && request.resource.data.colorCode in ['GREEN', 'YELLOW', 'RED', 'BLACK']
        && request.resource.data.behaviourScore is int
        && request.resource.data.createdAt is timestamp;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /surveys/{surveyId} {
      allow read: if isAuth();
      allow create: if isAuth() && validSurveyCreate();
      allow update: if isAdmin() || isWorker();
      allow delete: if isAdmin();
    }

    match /waste_reports/{reportId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isWorker();
      allow delete: if isAdmin();
    }

    match /behaviour_scores/{uid} {
      allow read: if isAuth();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /workers/{workerId} {
      allow read: if isWorker() || isAdmin();
      allow write: if isAdmin();
    }

    match /analytics/{docId} {
      allow read: if isAdmin() || isWorker();
      allow write: if isAdmin();
    }
  }
}
